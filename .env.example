NODE_ENV=development

# Comma-separated tenant API keys for local development.
# Format: tenantId:apiKey,otherTenant:otherApiKey
TENANT_API_KEYS=fh-demo:replace-with-local-dev-key

# Storage driver. Use memory for tests/local experiments and file for early human testing.
STORAGE_DRIVER=memory
STORAGE_DATA_DIR=.voice-ai-data

# Telephony provider credentials. Do not commit real values.
TELEPHONY_PROVIDER=
TELEPHONY_ACCOUNT_ID=
TELEPHONY_AUTH_TOKEN=
# Comma-separated provider webhook secrets. Format: provider:secret
# When empty, local telephony webhook signature verification is disabled.
TELEPHONY_WEBHOOK_SECRETS=
TELNYX_EXECUTE_COMMANDS=false
TELNYX_API_KEY=
TELNYX_API_BASE_URL=https://api.telnyx.com/v2

# Speech and model providers. Keep server-side only unless explicitly public.
STT_PROVIDER=
STT_API_KEY=
TTS_PROVIDER=
TTS_API_KEY=
LLM_PROVIDER=
LLM_API_KEY=
FIRST_CALL_EXTRACTOR=deterministic
OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_BASE_URL=
OPENAI_TIMEOUT_MS=
FIRST_CALL_LLM_MIN_BASE_CONFIDENCE=

# Internal integrations.
CRM_API_BASE_URL=
CRM_API_TOKEN=
DISPATCH_API_BASE_URL=
DISPATCH_API_TOKEN=
